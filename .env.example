# Torah Study AI - Environment Variables

# LLM + Embeddings (both use Gemini)
GOOGLE_API_KEY=...

# Reranking
COHERE_API_KEY=...

# Weaviate (Elestio)
WEAVIATE_URL=https://your-weaviate.vm.elestio.app
WEAVIATE_USERNAME=root
WEAVIATE_PASSWORD=your-password

# Auth
JWT_SECRET=your-secret-key-here
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password

# LangFuse (optional)
LANGFUSE_SECRET_KEY=...
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_HOST=http://localhost:3000
